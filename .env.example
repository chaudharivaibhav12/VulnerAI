# ── LLM Provider ─────────────────────────────────────
# Set LLM_PROVIDER to "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-your_key_here   # only needed if LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o

# ── Datadog ──────────────────────────────────────────
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_APP_KEY=your_datadog_app_key_here
DATADOG_SITE=datadoghq.com

# ── Nimble ───────────────────────────────────────────
NIMBLE_API_KEY=your_nimble_api_key_here

# ── ClickHouse ───────────────────────────────────────
CLICKHOUSE_HOST=your_clickhouse_host
CLICKHOUSE_PORT=8443
CLICKHOUSE_DB=autopatch
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password

# ── Senso.ai ─────────────────────────────────────────
SENSO_API_KEY=your_senso_api_key_here
SENSO_BASE_URL=https://api.senso.ai

# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ── Agent Config ─────────────────────────────────────
LOG_LEVEL=INFO
DRY_RUN=false
